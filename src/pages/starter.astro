---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
import { u } from "../lib/url";
import { site, primaryCta, navigation } from "../data/site";

const packages = [
  {
    id: "starter",
    theme: "bakery",
    bg: "/img/starter/baeckerei.jpg",
    obj: null,
    video: "/video/brot-ofen.mp4",
    site: {
      logo: "Bäckerei Lang",
      eyebrow: "Handwerksbäckerei · seit 1962",
      h1: 'Täglich frisch.<br/><em>Aus der Region.</em>',
      sub: "Brot & Backwaren nach alter Rezeptur, täglich frisch gebacken.",
      cta1: "Zum Sortiment",
      cta2: "Über uns",
      navCta: "Bestellen",
    },
  },
  {
    id: "studio",
    theme: "painter",
    bg: null,
    obj: null,
    site: {
      logo: "Maler Huber GmbH",
      eyebrow: "Malermeister · Inntal",
      h1: 'Farbe,<br/><em>die bleibt.</em>',
      sub: "Professionelle Malerarbeiten für Privat & Gewerbe im Inntal.",
      cta1: "Anfrage stellen",
      cta2: "Referenzen",
      navCta: "Anfrage",
    },
  },
  {
    id: "premium",
    theme: "dental",
    bg: null,
    obj: null,
    film: ["/img/starter/za-1.jpg", "/img/starter/za-2.jpg", "/img/starter/za-3.jpg", "/img/starter/za-4.jpg"],
    site: {
      logo: "Dr. Weber Zahnarztpraxis",
      eyebrow: "Zahnarztpraxis · Rosenheim",
      h1: 'Ihr strahlendes<br/><em>Lächeln.</em>',
      sub: "Modernste Zahntechnik mit persönlicher Betreuung für die ganze Familie.",
      cta1: "Termin buchen",
      cta2: "Behandlungen",
      navCta: "Termin",
    },
  },
];
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Drei Website-Starter von DT Webstudio — Starter, Studio und Premium. Finde das Paket, das zu deinem Betrieb passt." />
  <link rel="icon" type="image/svg+xml" href={u("/favicon.svg")} />
  <link rel="stylesheet" href={u("/fonts/fonts.css")} />
  <meta name="theme-color" content="#f8f6f1" />
  <title>Website-Starter · {site.name}</title>
</head>

<body>
  <a href="#main" class="skip">Zum Inhalt springen</a>

  <!-- Nav -->
  <header class="st-nav">
    <a href={u("/")} aria-label="DT Webstudio – Startseite" class="st-nav-logo">
      <Logo />
    </a>
    <nav class="st-nav-links" aria-label="Hauptnavigation">
      {navigation.map(item => (
        <a
          href={u(item.href)}
          class={`st-nav-link${item.href === "/starter" ? " st-nav-link--active" : ""}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a href={u(primaryCta.href)} class="btn btn-primary btn-sm">Projekt anfragen</a>
  </header>

  <!-- Schwebender Menü-Button: bleibt sichtbar, auch wenn die Leiste im Demo-Pin ausblendet -->
  <button
    id="stMenuBtn"
    class="st-menu-btn"
    aria-label="Menü öffnen"
    aria-expanded="false"
    aria-controls="stMenu"
  >
    <span class="st-menu-bars" aria-hidden="true"></span>
  </button>

  <!-- Vollbild-Menü (liegt über allem, auch über den gepinnten Demo-Sites) -->
  <div id="stMenu" class="st-menu" aria-hidden="true">
    <nav class="st-menu-nav" aria-label="Seitenmenü">
      {navigation.map(item => (
        <a
          href={u(item.href)}
          class={`st-menu-link${item.href === "/starter" ? " st-menu-link--active" : ""}`}
        >
          {item.label}
        </a>
      ))}
      <a href={u(primaryCta.href)} class="btn btn-primary st-menu-cta">{primaryCta.label}</a>
    </nav>
  </div>

  <!-- Scroll progress line -->
  <div class="st-progress" aria-hidden="true">
    <div class="st-progress-fill" id="stProgress"></div>
  </div>

  <!-- Intro -->
  <section class="st-intro" id="main">
    <div class="st-intro-inner">
      <span class="st-intro-ey">Referenz</span>
      <h1 class="st-intro-h1">So könnte deine<br /><em>Website aussehen.</em></h1>
      <p class="st-intro-sub">Hier sind drei kurze Animationen, wie eine Website gestaltet sein könnte.</p>
    </div>
    <div class="st-intro-hint" aria-hidden="true">
      <span class="st-hint-label">scroll</span>
      <div class="st-hint-line"></div>
    </div>
  </section>

  <!-- Websites: fullscreen scroll-zoom sequence -->
  <div class="st-sites-wrap">
    <div class="st-sites-pin" id="stSitesPin">
      {packages.map((pkg) => (
        <div class={`st-site st-site--${pkg.theme}`} aria-label={pkg.site.logo}>
          {pkg.bg && (
            <img class="fs-bg" src={pkg.bg} alt="" loading="eager" decoding="async" />
          )}
          {pkg.video && (
            <video class="fs-video" id="fsVideo" src={pkg.video} muted playsinline preload="auto" aria-hidden="true"></video>
          )}
          {pkg.film && (
            <div class="fs-film" aria-hidden="true">
              {pkg.film.map((src, fi) => (
                <img class="fs-film-img" src={src} alt="" loading={fi === 0 ? "eager" : "lazy"} decoding="async" />
              ))}
            </div>
          )}
          <div class="fs-scrim" aria-hidden="true"></div>
          {pkg.obj && (
            <img class="fs-obj" src={pkg.obj} alt="" loading="lazy" decoding="async" />
          )}
          {pkg.theme === "painter" && (
            <>
              <img class="fs-brush" src="/img/starter/brush.png" alt="" loading="lazy" decoding="async" />
              <img class="fs-werk" src="/img/starter/werk.jpg" alt="" loading="lazy" decoding="async" />
              <img class="fs-pinsel" src="/img/starter/obj-pinsel.png" alt="" loading="lazy" decoding="async" />
            </>
          )}
          <nav class="fs-nav">
            <span class="fs-logo">{pkg.site.logo}</span>
            <div class="fs-links"><span></span><span></span><span></span><span></span></div>
            <span class="fs-navcta">{pkg.site.navCta}</span>
          </nav>
          <div class="fs-hero">
            <span class="fs-eyebrow">{pkg.site.eyebrow}</span>
            <h2 class={`fs-h1${pkg.theme === "painter" ? " fs-h1--reveal" : ""}`} set:html={pkg.site.h1}></h2>
            <p class="fs-sub">{pkg.site.sub}</p>
            <div class="fs-btns">
              <span class="fs-btn fs-btn--primary">{pkg.site.cta1}</span>
              <span class="fs-btn fs-btn--ghost">{pkg.site.cta2}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- End CTA -->
  <section class="st-end">
    <div class="st-end-inner">
      <h2 class="st-end-h">Gefällt dir eine Richtung?</h2>
      <p class="st-end-sub">Das sind nur Beispiele — deine Seite bauen wir individuell für deinen Betrieb.</p>
      <a href={u(primaryCta.href)} class="btn btn-primary">Kostenlos anfragen</a>
      <a href={u("/")} class="st-back">← Zurück zur Startseite</a>
    </div>
  </section>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; }
    body { font-family: var(--font-sans); background: #f8f6f1; overflow-x: hidden; }
    a { text-decoration: none; }

    .skip {
      position: absolute; left: -999px; top: 0;
      background: var(--color-accent); color: #fff; padding: .5rem 1rem;
      border-radius: 6px; z-index: 200;
    }
    .skip:focus { left: 1rem; top: 1rem; }

    /* ── Progress ── */
    .st-progress {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 2px; background: rgba(194,74,44,.15); pointer-events: none;
    }
    .st-progress-fill {
      height: 100%; background: var(--color-accent);
      transform-origin: left; transform: scaleX(0);
      transition: transform .06s linear;
    }

    /* ── Nav ── */
    .st-nav {
      position: fixed; inset-inline: 0; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem;
      padding: .9rem clamp(1.5rem, 4vw, 2.5rem);
      background: rgba(248,246,241,.9); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(24,25,27,.08);
    }
    .st-nav-links {
      display: flex; align-items: center; gap: .2rem;
      flex: 1; justify-content: center;
    }
    .st-nav-link {
      font-size: .85rem; font-weight: 500; color: var(--color-ink-500);
      padding: .3rem .65rem; border-radius: 6px;
      transition: color .18s, background .18s;
    }
    .st-nav-link:hover { color: var(--color-ink-900); background: rgba(24,25,27,.05); }
    .st-nav-link--active { color: var(--color-ink-900); font-weight: 600; }
    @media (max-width: 900px) { .st-nav-links { display: none; } }

    /* ── Schwebender Menü-Button + Vollbild-Menü ── */
    .st-menu-btn {
      position: fixed; top: .75rem; right: clamp(1rem, 3vw, 1.6rem); z-index: 10002;
      width: 44px; height: 44px;
      display: none; align-items: center; justify-content: center;
      border: 1px solid rgba(24,25,27,.1); border-radius: 999px;
      background: rgba(248,246,241,.92); backdrop-filter: blur(12px);
      cursor: pointer; padding: 0;
      box-shadow: 0 6px 24px -10px rgba(0,0,0,.3);
    }
    .st-menu-bars {
      position: relative; width: 20px; height: 1.5px; background: #18191b;
      transition: background-color .2s;
    }
    .st-menu-bars::before, .st-menu-bars::after {
      content: ""; position: absolute; left: 0; width: 20px; height: 1.5px;
      background: #18191b; transition: transform .3s ease;
    }
    .st-menu-bars::before { transform: translateY(-6px); }
    .st-menu-bars::after  { transform: translateY(6px); }
    .st-menu-btn[aria-expanded="true"] .st-menu-bars { background: transparent; }
    .st-menu-btn[aria-expanded="true"] .st-menu-bars::before { transform: rotate(45deg); }
    .st-menu-btn[aria-expanded="true"] .st-menu-bars::after  { transform: rotate(-45deg); }

    /* Mobile: Button immer sichtbar (Leisten-Links sind ausgeblendet),
       CTA der Leiste wandert ins Menü, damit nichts unter dem Button liegt */
    @media (max-width: 900px) {
      .st-menu-btn { display: flex; }
      .st-nav > .btn { display: none; }
    }
    /* Desktop: Button erscheint nur, während die Leiste im Demo-Pin ausgeblendet ist */
    @media (min-width: 901px) {
      body.st-pinned .st-menu-btn { display: flex; }
    }

    .st-menu {
      position: fixed; inset: 0; z-index: 10001;
      background: rgba(13,12,15,.97); backdrop-filter: blur(10px);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; visibility: hidden; transform: translateY(-8px);
      transition: opacity .3s ease, visibility .3s ease, transform .3s ease;
    }
    .st-menu--open { opacity: 1; visibility: visible; transform: none; }
    .st-menu-nav {
      display: flex; flex-direction: column;
      width: min(85vw, 22rem);
    }
    .st-menu-link {
      font-family: var(--font-display); font-size: 1.7rem; color: #f4f1ec;
      padding: .8rem 0; border-bottom: 1px solid rgba(244,241,236,.12);
      transition: color .18s;
    }
    .st-menu-link:hover { color: var(--color-accent); }
    .st-menu-link--active { color: var(--color-accent); }
    .st-menu-cta { margin-top: 1.6rem; align-self: flex-start; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      padding: .8rem 1.6rem; border-radius: 10px; font-weight: 600; font-size: 1rem;
    }
    .btn-primary {
      background: var(--color-accent); color: #fff;
      transition: background .2s, transform .2s;
    }
    .btn-primary:hover { background: #a83a1e; transform: translateY(-1px); }
    .btn-sm { padding: .5rem 1.1rem; font-size: .88rem; }

    /* ── Intro ── */
    .st-intro {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: clamp(8rem, 16vh, 11rem) clamp(1.5rem, 5vw, 4rem) clamp(4rem, 8vh, 6rem);
      background: #0d0c0f;
      position: relative;
    }
    .st-intro-inner { position: relative; z-index: 1; }
    .st-intro-ey {
      display: inline-block; font-size: .78rem; font-weight: 600;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--color-accent); margin-bottom: 1.2rem;
    }
    .st-intro-h1 {
      font-family: var(--font-display); font-size: clamp(2.8rem, 7vw, 5.2rem);
      font-weight: 500; line-height: 1.02; letter-spacing: -.03em;
      color: #f4f1ec; margin: 0 0 1.2rem;
    }
    .st-intro-h1 em { font-style: italic; color: var(--color-accent); }
    .st-intro-sub {
      color: rgba(244,241,236,.55); font-size: clamp(1rem, 1.8vw, 1.15rem);
      line-height: 1.6; max-width: 30rem; margin: 0 auto;
    }
    .st-intro-hint {
      position: absolute; bottom: clamp(2rem, 5vh, 3.5rem); left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
    }
    .st-hint-label {
      font-size: .7rem; letter-spacing: .22em; text-transform: uppercase;
      color: rgba(244,241,236,.4);
    }
    .st-hint-line {
      width: 1px; height: 40px;
      background: linear-gradient(rgba(244,241,236,.4), transparent);
      animation: hint-drop 2s ease-in-out infinite;
    }
    @keyframes hint-drop {
      0%,100% { transform: scaleY(1); opacity: .7; }
      50%      { transform: scaleY(.5); opacity: .3; }
    }

    /* ── Fullscreen site wrapper ── */
    .st-sites-wrap {
      position: relative;
    }
    .st-sites-pin {
      position: relative;
      width: 100%; height: 100vh;
      overflow: hidden;
      z-index: 9999;
    }
    .st-site {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      will-change: transform, opacity;
    }

    /* ━━━ Fullscreen-Website-Layout ━━━ */

    /* Site-Hintergrundfarben */
    .st-site--bakery  { background: #120702; }
    .st-site--painter { background: #f8f6f1; }
    .st-site--dental  { background: #020411; }

    /* Hintergrundfoto (Bäckerei) */
    .fs-bg {
      position: absolute; inset: 0; z-index: 0;
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 30%;
      display: block;
    }

    /* Gradient-Scrim für Textlesbarkeit */
    .fs-scrim {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
    }
    .st-site--bakery .fs-scrim {
      background:
        linear-gradient(to top,  rgba(10,4,1,.94) 0%, rgba(10,4,1,.62) 30%, rgba(10,4,1,.12) 55%, transparent 72%),
        linear-gradient(to bottom, rgba(5,2,0,.55) 0%, transparent 20%);
    }
    .st-site--painter .fs-scrim { background: none; }

    /* Ofen-Video (Bäckerei): läuft scrollgetrieben ab */
    .fs-video {
      position: absolute; inset: 0; z-index: 0;
      width: 100%; height: 100%;
      object-fit: cover; display: block;
    }
    .st-site--dental .fs-scrim {
      background:
        linear-gradient(to top, rgba(1,2,10,.92) 0%, rgba(1,2,10,.55) 30%, rgba(1,2,10,.08) 58%, transparent 75%),
        linear-gradient(to bottom, rgba(1,2,10,.5) 0%, transparent 20%);
    }

    /* Fotofilm (Zahnarzt): Ken-Burns-Crossfade-Stack */
    .fs-film { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
    .fs-film-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      opacity: 0; will-change: transform, opacity;
    }

    /* Maler: Werkbild rechts neben der Hero-Schrift, wird vom Pinsel mit freigelegt */
    .fs-werk {
      position: absolute; z-index: 5;
      right: clamp(2rem, 6vw, 7rem); bottom: clamp(7rem, 18vh, 13rem);
      width: clamp(280px, 34vw, 520px);
      border-radius: 14px;
      box-shadow: 0 30px 70px -20px rgba(24,25,27,.35);
      clip-path: inset(0 100% 0 0 round 14px);
      will-change: clip-path;
    }

    /* Maler: Amber-Strich liegt hinter der Headline, wird per clip-path
       aufgedeckt, während der 3D-Pinsel scrollgetrieben drüberzieht */
    .fs-brush {
      position: absolute; z-index: 4;
      left: -4%; bottom: clamp(9rem, 24vh, 16rem);
      width: 108%; max-width: none;
      opacity: .92;
      pointer-events: none;
      clip-path: inset(0 100% 0 0);
      will-change: clip-path;
    }
    .fs-pinsel {
      position: absolute; z-index: 7;
      left: 0; bottom: clamp(8rem, 20vh, 14rem);
      width: clamp(200px, 24vw, 360px);
      pointer-events: none;
      will-change: transform;
      transform: rotate(-8deg);
      filter: drop-shadow(0 24px 44px rgba(0,0,0,.28));
    }
    /* Headline startet verdeckt, wird vom Pinselstrich freigelegt */
    .fs-h1--reveal { clip-path: inset(0 100% -8% 0); }

    /* Schwebendes 3D-Objekt (GSAP: Float + Maus-Parallax) */
    .fs-obj {
      position: absolute; z-index: 4;
      right: clamp(4rem, 10vw, 12rem);
      top: 50%;
      width: clamp(240px, 30vw, 440px);
      /* translate-Property statt transform: GSAP schreibt transform und
         würde den vertikalen Offset sonst überschreiben */
      translate: 0 -58%;
      filter: drop-shadow(0 40px 60px rgba(0,0,0,.45));
      pointer-events: none;
      will-change: transform;
    }
    .st-site--bakery .fs-obj { top: 44%; right: clamp(3rem, 8vw, 10rem); }
    @media (max-width: 767px) {
      .fs-obj { width: clamp(170px, 46vw, 260px); right: 6vw; top: 38%; }
    }

    /* Nav */
    .fs-nav {
      position: absolute; top: 0; left: 0; right: 0; z-index: 10;
      display: flex; align-items: center; gap: clamp(2rem, 4vw, 4rem);
      padding: clamp(1.2rem, 2.5vh, 1.8rem) clamp(2.5rem, 6vw, 6rem);
    }
    .fs-logo {
      font-family: var(--font-display); font-size: clamp(1rem, 1.6vw, 1.35rem);
      font-weight: 600; letter-spacing: -.01em; white-space: nowrap;
    }
    .fs-links { display: flex; gap: .6rem; flex: 1; align-items: center; }
    .fs-links span { display: block; height: .42rem; border-radius: 99px; }
    .fs-links span:nth-child(1) { width: clamp(4rem,5vw,6rem); }
    .fs-links span:nth-child(2) { width: clamp(5rem,6.5vw,8rem); }
    .fs-links span:nth-child(3) { width: clamp(3.5rem,4.5vw,5.5rem); }
    .fs-links span:nth-child(4) { width: clamp(3rem,4vw,5rem); }
    .fs-navcta {
      font-size: clamp(.8rem, 1.1vw, 1rem); font-weight: 700;
      padding: .6em 1.8em; border-radius: 10px; white-space: nowrap;
    }

    /* Hero: Text unten links — klassisch editorial */
    .fs-hero {
      position: absolute; bottom: 0; left: 0; right: 0; z-index: 5;
      padding: 0 clamp(3rem, 7vw, 8rem) clamp(4.5rem, 10vh, 7rem);
      max-width: 72rem;
      display: flex; flex-direction: column; gap: clamp(.9rem, 1.5vh, 1.4rem);
    }
    .fs-eyebrow {
      font-size: clamp(.65rem, .9vw, .8rem); font-weight: 700;
      letter-spacing: .2em; text-transform: uppercase;
    }
    .fs-h1 {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 8vw, 7.5rem);
      font-weight: 500; line-height: .96; letter-spacing: -.04em;
      margin: 0;
    }
    .fs-h1 em { font-style: italic; }
    .fs-sub {
      font-size: clamp(.95rem, 1.5vw, 1.15rem); line-height: 1.6;
      max-width: 36rem; opacity: .75;
    }
    .fs-btns { display: flex; gap: .9rem; flex-wrap: wrap; margin-top: .4rem; }
    .fs-btn {
      font-size: clamp(.85rem, 1.1vw, 1rem); font-weight: 700;
      padding: .8em 2.2em; border-radius: 12px; white-space: nowrap;
    }

    /* ── Bakery (cineastisch dunkel — Ofen-Video als Held) ── */
    .st-site--bakery .fs-nav { background: rgba(10,4,1,.5); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,180,80,.1); }
    .st-site--bakery .fs-logo { color: #f8e8c8; }
    .st-site--bakery .fs-links span { background: rgba(248,232,200,.22); }
    .st-site--bakery .fs-navcta { background: #D4821A; color: #fff; }
    .st-site--bakery .fs-eyebrow { color: #e8a046; }
    .st-site--bakery .fs-h1 { color: #fff5e6; }
    .st-site--bakery .fs-h1 em { color: #f5b86e; }
    .st-site--bakery .fs-sub { color: rgba(255,235,195,.78); }
    .st-site--bakery .fs-btn--primary { background: #D4821A; color: #fff; }
    .st-site--bakery .fs-btn--ghost { background: rgba(255,255,255,.1); color: #fff5e6; border: 2px solid rgba(255,200,100,.25); }

    /* ── Painter (weiß, Pinselstrich streicht die Headline) ── */
    .st-site--painter .fs-nav { background: rgba(248,246,241,.85); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(24,25,27,.07); }
    .st-site--painter .fs-logo { color: #18191b; }
    .st-site--painter .fs-links span { background: rgba(24,25,27,.14); }
    .st-site--painter .fs-navcta { background: #e8a020; color: #241a05; }
    .st-site--painter .fs-eyebrow { color: #b07708; }
    .st-site--painter .fs-h1 { color: #18191b; }
    .st-site--painter .fs-h1 em { color: #e8a020; }
    .st-site--painter .fs-sub { color: rgba(24,25,27,.6); }
    .st-site--painter .fs-btn--primary { background: #e8a020; color: #241a05; }
    .st-site--painter .fs-btn--ghost { background: transparent; color: #18191b; border: 2px solid rgba(24,25,27,.18); }

    /* ── Dental (kosmisch blau) ── */
    .st-site--dental .fs-nav { background: rgba(1,2,14,.72); backdrop-filter: blur(18px); border-bottom: 1px solid rgba(100,180,255,.09); }
    .st-site--dental .fs-logo { color: #e8f4ff; }
    .st-site--dental .fs-links span { background: rgba(200,230,255,.2); }
    .st-site--dental .fs-navcta { background: #4a9eff; color: #fff; }
    .st-site--dental .fs-eyebrow { color: #7cc8ff; }
    .st-site--dental .fs-h1 { color: #ffffff; }
    .st-site--dental .fs-h1 em { color: #7cc8ff; }
    .st-site--dental .fs-sub { color: rgba(220,240,255,.6); }
    .st-site--dental .fs-btn--primary { background: #4a9eff; color: #fff; }
    .st-site--dental .fs-btn--ghost { background: rgba(255,255,255,.07); color: #e8f4ff; border: 2px solid rgba(100,180,255,.22); }

    /* ── End CTA ── */
    .st-end {
      padding: clamp(6rem, 16vh, 10rem) 1.5rem;
      background: var(--color-paper-100);
    }
    .st-end-inner {
      max-width: 38rem; margin-inline: auto;
      display: flex; flex-direction: column; align-items: center;
      gap: 1.25rem; text-align: center;
    }
    .st-end-h {
      font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 500; letter-spacing: -.02em; line-height: 1.08;
      color: var(--color-ink-900); margin: 0;
    }
    .st-end-sub {
      color: var(--color-ink-500); font-size: clamp(.95rem, 1.5vw, 1.05rem);
      line-height: 1.6; max-width: 32rem;
    }
    .st-back { font-size: .9rem; color: var(--color-ink-400); transition: color .2s; }
    .st-back:hover { color: var(--color-ink-700); }

    /* ── Mobile-Feinschliff für die Demo-Sites ── */
    @media (max-width: 767px) {
      /* rechts Platz lassen für den schwebenden Menü-Button */
      .fs-nav { gap: 1rem; padding: 1rem 4.75rem 1rem 1.25rem; justify-content: space-between; }
      .fs-links { display: none; }
      .fs-logo { flex: 1; font-size: 1.05rem; }
      .fs-navcta { font-size: .8rem; }

      .fs-hero { padding: 0 1.25rem 4.5rem; gap: .8rem; }
      .fs-h1 { font-size: clamp(2.6rem, 12vw, 3.2rem); }
      .fs-sub { font-size: .95rem; }
      .fs-btn { font-size: .85rem; padding: .75em 1.6em; }

      /* Maler: Werkbild als kleine Karte oben rechts statt über dem Text */
      .fs-werk { top: 5.5rem; bottom: auto; right: 1.25rem; width: 46vw; }
      .fs-pinsel { width: clamp(120px, 36vw, 170px); bottom: 26vh; }
      .fs-brush { bottom: 30vh; }
    }

    @media (prefers-reduced-motion: reduce) {
      .st-hint-line { animation: none !important; }
    }
  </style>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fill = document.getElementById("stProgress");

    // Vollbild-Menü — funktioniert jederzeit, auch während des Demo-Pins
    const menuBtn = document.getElementById("stMenuBtn");
    const menuEl = document.getElementById("stMenu");
    const setMenu = (open: boolean) => {
      if (!menuBtn || !menuEl) return;
      menuBtn.setAttribute("aria-expanded", String(open));
      menuBtn.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
      menuEl.classList.toggle("st-menu--open", open);
      menuEl.setAttribute("aria-hidden", String(!open));
      document.body.style.overflow = open ? "hidden" : "";
    };
    menuBtn?.addEventListener("click", () =>
      setMenu(menuBtn.getAttribute("aria-expanded") !== "true"));
    menuEl?.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false)));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setMenu(false);
    });

    // Scroll progress bar
    if (fill) {
      ScrollTrigger.create({
        start: "top top",
        end: "bottom bottom",
        onUpdate(self) {
          fill.style.transform = `scaleX(${self.progress})`;
        },
      });
    }

    if (!reduce) {
      const sites = gsap.utils.toArray<HTMLElement>(".st-site");

      // Initial z-stack: site 0 on top, others behind at reduced scale
      gsap.set(sites[0], { scale: 1, opacity: 1, zIndex: 3 });
      gsap.set(sites[1], { scale: 0.86, opacity: 0, zIndex: 2 });
      gsap.set(sites[2], { scale: 0.86, opacity: 0, zIndex: 1 });

      // Hide the starter nav while the demo sites are pinned fullscreen.
      // body.st-pinned zeigt währenddessen den schwebenden Menü-Button (Desktop).
      const stNav = document.querySelector<HTMLElement>('.st-nav');
      const hideNav = () => {
        gsap.to(stNav, { opacity: 0, duration: 0.2, pointerEvents: 'none' });
        document.body.classList.add('st-pinned');
      };
      const showNav = () => {
        gsap.to(stNav, { opacity: 1, duration: 0.3, pointerEvents: 'auto' });
        document.body.classList.remove('st-pinned');
      };
      ScrollTrigger.create({
        trigger: "#stSitesPin",
        start: "top top",
        end: "+=300%",
        onEnter: hideNav,
        onLeave: showNav,
        onEnterBack: hideNav,
        onLeaveBack: showNav,
      });

      // One pinned timeline drives the zoom-through all three sites
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: "#stSitesPin",
          start: "top top",
          end: "+=300%",
          pin: true,
          anticipatePin: 1,
          scrub: 1.6,
          invalidateOnRefresh: true,
          // Fortschritt für die 3D-Brot-Szene (Bäckerei) bereitstellen
          onUpdate: (self) => { (window as any).__stProgress = self.progress; },
        },
      });

      // Phase 1: zoom through site 0 → arrive at site 1
      tl.to(sites[0], { scale: 1.18, opacity: 0, ease: "power2.in", duration: 1 }, 0)
        .set(sites[1], { zIndex: 3 }, 0.55)
        .to(sites[1], { scale: 1, opacity: 1, ease: "power2.out", duration: 1 }, 0.65);

      // Phase 2: zoom through site 1 → arrive at site 2
      tl.to(sites[1], { scale: 1.18, opacity: 0, ease: "power2.in", duration: 1 }, 1.7)
        .set(sites[2], { zIndex: 3 }, 2.25)
        .to(sites[2], { scale: 1, opacity: 1, ease: "power2.out", duration: 1 }, 2.35);

      // Maler: 3D-Pinsel zieht von links nach rechts über den Screen,
      // dahinter wachsen Amber-Strich + Headline auf (Site 1 sichtbar ~0.65–1.7)
      tl.fromTo(".fs-pinsel",
          { x: "-30vw", y: "4vh", rotation: -8 },
          { x: "108vw", y: "-2vh", rotation: -3, ease: "none", duration: 0.7 }, 0.8)
        .fromTo(".fs-brush",
          { clipPath: "inset(0 100% 0 0)" },
          { clipPath: "inset(0 -2% 0 0)", ease: "none", duration: 0.62 }, 0.84)
        .fromTo(".fs-h1--reveal",
          { clipPath: "inset(0 100% -8% 0)" },
          { clipPath: "inset(0 -6% -8% 0)", ease: "none", duration: 0.55 }, 0.87)
        // Werkbild rechts wird vom selben Strich mit aufgedeckt
        .fromTo(".fs-werk",
          { clipPath: "inset(0 100% 0 0 round 14px)" },
          { clipPath: "inset(0 0% 0 0 round 14px)", ease: "none", duration: 0.4 }, 1.05);

      // 3D-Objekte: permanenter Float + sanfte Rotation
      gsap.utils.toArray<HTMLElement>(".fs-obj").forEach((obj, i) => {
        gsap.to(obj, {
          y: i % 2 ? 22 : -26,
          rotation: i % 2 ? -4 : 4,
          duration: 3.2 + i * 0.7,
          ease: "sine.inOut",
          repeat: -1,
          yoyo: true,
        });
      });

      // Maus-Parallax (nur x — y gehört der Float-Animation)
      const pin = document.getElementById("stSitesPin");
      if (pin) {
        const quickX = gsap.utils.toArray<HTMLElement>(".fs-obj").map(o =>
          gsap.quickTo(o, "x", { duration: 0.6, ease: "power2.out" }));
        pin.addEventListener("mousemove", (e) => {
          const nx = (e.clientX / window.innerWidth - 0.5) * 2;
          quickX.forEach(q => q(nx * 26));
        });
      }

      // Zahnarzt: Fotofilm — Ken-Burns-Crossfade in Endlosschleife
      const filmImgs = gsap.utils.toArray<HTMLElement>(".fs-film-img");
      if (filmImgs.length) {
        const HOLD = 3.4, FADE = 1.4;
        const film = gsap.timeline({ repeat: -1 });
        filmImgs.forEach((img, i) => {
          const at = i * (HOLD + FADE);
          film.fromTo(img, { opacity: 0 }, { opacity: 1, duration: FADE, ease: "power1.inOut" }, at)
              .fromTo(img, { scale: 1.02 }, { scale: 1.14, duration: HOLD + FADE * 2, ease: "none" }, at)
              .to(img, { opacity: 0, duration: FADE, ease: "power1.inOut" }, at + HOLD + FADE);
        });
        // letztes Crossfade überlappt sauber mit Bild 1 der nächsten Runde
        film.duration(filmImgs.length * (HOLD + FADE));
      }
    }

    // Bäckerei: Ofen-Video läuft scrollgetrieben ab (Scrub statt Autoplay).
    // Ohne JS/bei reduced motion bleibt das Standbild (fs-bg) sichtbar.
    {
      const video = document.getElementById("fsVideo") as HTMLVideoElement | null;
      if (video && !reduce) {
        let dur = 0;
        video.addEventListener("loadedmetadata", () => { dur = video.duration; });
        // Sanft zur Zielzeit nachziehen — direkte Sprünge ruckeln beim Scrubben
        gsap.ticker.add(() => {
          if (!dur) return;
          const p = Math.min(((window as any).__stProgress ?? 0) * 3, 1);
          const target = p * (dur - 0.06);
          const diff = target - video.currentTime;
          if (Math.abs(diff) > 0.04) video.currentTime += diff * 0.22;
        });
      }
    }
  </script>

</body>
</html>
