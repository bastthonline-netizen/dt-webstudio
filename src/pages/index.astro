---
import Layout from "../layouts/Layout.astro";
import LaptopZoom from "../components/LaptopZoom.astro";
import WebsiteReel from "../components/WebsiteReel.astro";
import { primaryCta } from "../data/site";
import { u } from "../lib/url";
---

<Layout>
  <LaptopZoom />

  <!-- ===== Hero Split: Pitch links · WebsiteReel rechts ===== -->
  <section class="hero-split" aria-label="Was wir bauen">
    <div class="hs-inner">

      <div class="hs-text">
        <span class="hs-eyebrow">Webstudio · Inntal &amp; Rosenheim</span>
        <h1 class="hs-title">
          Websites, die deinen<br />
          <span class="accent-em">Betrieb</span> widerspiegeln.
        </h1>
        <p class="hs-sub">
          Für Handwerk und kleine Betriebe in der Region —&nbsp;genau nach euren
          Wünschen, zu Preisen, die man sich leisten kann.
        </p>
        <div class="hs-cta-row">
          <a href={u(primaryCta.href)} class="btn btn-primary">{primaryCta.label}</a>
          <a href={u("/starter")} class="btn btn-secondary">Starter ansehen&nbsp;→</a>
        </div>
      </div>

      <div class="hs-reel">
        <WebsiteReel />
      </div>

    </div>
  </section>
</Layout>

<style>
  .hero-split {
    background: var(--color-paper-50);
    padding-block: clamp(5rem, 12vh, 9rem);
    overflow: hidden;
  }
  .hs-inner {
    width: 100%;
    max-width: 1240px;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 4vw, 2.5rem);
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hs-inner { grid-template-columns: 1fr 1fr; }
  }

  .hs-eyebrow {
    display: block;
    font-size: .78rem; font-weight: 600;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.1rem;
  }
  .hs-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -.025em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .hs-sub {
    margin-top: 1.25rem;
    max-width: 34rem;
    color: var(--color-ink-500);
    font-size: clamp(.95rem, 1.8vw, 1.1rem);
    line-height: 1.65;
  }
  .hs-cta-row {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }
  .hs-reel {
    display: flex;
    justify-content: center;
  }
</style>
