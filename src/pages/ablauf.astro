---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProcessStep from "../components/ProcessStep.astro";
import { process, primaryCta } from "../data/site";
import { u } from "../lib/url";
---

<Layout
  title="Ablauf"
  description="So entsteht Ihre Website bei DT Webstudio – vier klare Schritte vom Kennenlernen bis zum Launch."
>
  <!-- Page header -->
  <section class="bg-paper-50">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Ablauf"
        title='So entsteht Ihre <span class="accent-em">Website</span>.'
        lead="Ein klarer, ruhiger Ablauf in vier Schritten. Sie wissen jederzeit, woran wir gerade arbeiten."
      />
    </div>
  </section>

  <!-- Process steps -->
  <section class="bg-paper-100">
    <div class="container-wide grid gap-12 py-16 md:py-24 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <p class="text-ink-500 text-[1.05rem] leading-relaxed max-w-sm">
          Kein starres Schema, keine Überraschungen. Wir halten Sie bei jedem Schritt auf dem Laufenden — persönlich und direkt.
        </p>
        <a href={u(primaryCta.href)} class="btn btn-primary mt-8 inline-flex">
          {primaryCta.label}
        </a>
      </div>
      <ol class="lg:pt-2">
        {process.map((step, i) => (
          <ProcessStep step={step} index={i} last={i === process.length - 1} />
        ))}
      </ol>
    </div>
  </section>
</Layout>
