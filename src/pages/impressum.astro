---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";
---

<Layout title="Impressum" description="Impressum von DT Webstudio.">
  <article class="container-narrow pb-24 pt-[calc(var(--header-h)+4rem)]">
    <h1 class="text-4xl sm:text-5xl">Impressum</h1>

    <div class="mt-10 space-y-8 text-ink-700 [&_h2]:mt-8 [&_h2]:text-xl [&_h2]:text-ink-900 [&_p]:mt-2 [&_p]:leading-relaxed">
      <section>
        <h2>Angaben gemäß § 5 DDG</h2>
        <p>{site.address.company}</p>
        <p>Vertreten durch die Gesellschafter: {site.partners.join(" und ")}</p>
        <p>{site.address.street}</p>
        <p>{site.address.zip} {site.address.city}</p>
        <p>{site.address.country}</p>
      </section>

      <section>
        <h2>Kontakt</h2>
        <p>Telefon: {site.phone}</p>
        <p>E-Mail: {site.email}</p>
      </section>

      <section>
        <h2>Umsatzsteuer</h2>
        <p>
          Als Kleinunternehmer im Sinne von § 19 UStG erheben wir keine Umsatzsteuer
          und weisen diese daher nicht aus. Eine Umsatzsteuer-Identifikationsnummer
          besteht nicht.
        </p>
      </section>

      <section>
        <h2>Verantwortlich für den Inhalt</h2>
        <p>{site.owner}, Anschrift wie oben.</p>
      </section>
    </div>
  </article>
</Layout>
