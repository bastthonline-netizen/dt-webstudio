---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { pricing, primaryCta } from "../data/site";
import { u } from "../lib/url";
---

<Layout
  title="Preise"
  description="Faire Website-Preise für kleine Betriebe und Vereine — deutlich günstiger als typische Agentur-Angebote. Preis je nach Projekt, unverbindlich anfragen."
>
  <!-- Page header -->
  <section class="bg-paper-50">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Preise"
        title='Faire Preise für <span class="accent-em">kleine Betriebe</span>.'
        lead={pricing.note}
      />
    </div>
  </section>

  <!-- Pricing packages -->
  <section class="bg-paper-100">
    <div class="container-wide py-16 md:py-24">
      <div class="grid gap-5 md:grid-cols-2">
        {pricing.packages.map((p) => (
          <article class="card reveal flex flex-col p-8">
            <h3 class="text-xl text-ink-900">{p.name}</h3>
            <p class="mt-3 font-display text-4xl text-accent">{p.price}</p>
            <p class="mt-4 text-[0.97rem] leading-relaxed text-ink-500">{p.desc}</p>
            <a href={u(primaryCta.href)} class="btn btn-primary mt-7 self-start">
              {primaryCta.label}
            </a>
          </article>
        ))}
      </div>

      <div class="reveal mt-10 rounded-[var(--radius-card)] border border-line bg-paper-50 p-7 md:p-9">
        <h3 class="font-display text-xl text-ink-900">Das klären wir vorher gemeinsam</h3>
        <ul class="mt-6 grid gap-x-10 gap-y-4 sm:grid-cols-2">
          {pricing.factors.map((f) => (
            <li class="border-t border-line pt-4 text-[0.97rem] leading-relaxed text-ink-700">{f}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-paper-50">
    <div class="container-wide py-20 md:py-28 text-center">
      <h2 class="font-display text-3xl text-ink-900 mb-4">
        Noch Fragen zum <span class="accent-em">Preis</span>?
      </h2>
      <p class="text-ink-500 text-lg mb-8 max-w-md mx-auto">
        Kein Problem — wir klären alles im ersten Gespräch, kostenlos und ohne Verpflichtung.
      </p>
      <a href={u(primaryCta.href)} class="btn btn-primary">{primaryCta.label}</a>
    </div>
  </section>
</Layout>
