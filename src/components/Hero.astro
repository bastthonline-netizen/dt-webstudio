---
import { primaryCta } from "../data/site";
import { u } from "../lib/url";
---

<section
  class="relative flex items-center overflow-hidden pt-[var(--header-h)] lg:min-h-[100dvh]"
>
  <!-- Sanfter Akzent-Schimmer im Hintergrund -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-[10%] top-[6%] h-[60vh] w-[60vh] rounded-full opacity-60 blur-[90px]"
    style="background: radial-gradient(circle, var(--color-accent-soft), transparent 70%);"
  >
  </div>

  <div class="container-wide relative grid items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8">
    <!-- Text -->
    <div class="max-w-xl">
      <span class="eyebrow reveal">Webstudio · Inntal &amp; Rosenheim</span>

      <h1
        class="reveal mt-6 text-[2.6rem] leading-[1.04] sm:text-6xl lg:text-[4.1rem]"
        style="--reveal-delay: 80ms;"
      >
        Handgemachte Websites, die <span class="accent-em">auffallen</span>.
      </h1>

      <p
        class="reveal mt-6 max-w-md text-lg leading-relaxed text-ink-500"
        style="--reveal-delay: 160ms;"
      >
        Hochwertig gestaltet, blitzschnell und persönlich betreut – für Betriebe
        und Vereine aus der Region.
      </p>

      <div class="reveal mt-9 flex flex-wrap items-center gap-3" style="--reveal-delay: 240ms;">
        <a href={u(primaryCta.href)} class="btn btn-primary">{primaryCta.label}</a>
        <a href={u("/#leistungen")} class="btn btn-secondary">Leistungen ansehen</a>
      </div>
    </div>

    <!-- 3D-Showpiece -->
    <div class="relative aspect-square w-full max-w-[520px] justify-self-center lg:max-w-none">
      <canvas
        id="hero-canvas"
        class="h-full w-full"
        role="img"
        aria-label="Abstraktes, sich langsam drehendes 3D-Objekt als visuelles Markenzeichen"
      ></canvas>
      <!-- Fallback, falls kein WebGL -->
      <div
        id="hero-fallback"
        aria-hidden="true"
        class="absolute inset-0 hidden items-center justify-center"
      >
        <div
          class="h-2/3 w-2/3 rounded-[28%] opacity-90"
          style="background: conic-gradient(from 140deg, var(--color-accent), var(--color-paper-200), var(--color-ink-800), var(--color-accent));"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
  const fallback = document.getElementById("hero-fallback");

  function showFallback() {
    canvas?.classList.add("hidden");
    fallback?.classList.remove("hidden");
    fallback?.classList.add("flex");
  }

  if (!canvas) {
    // nichts zu tun
  } else {
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    } catch {
      showFallback();
      throw new Error("kein WebGL");
    }

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
    camera.position.set(0, 0, 6.2);

    // Faceted, leicht organisch verformte Ikosaeder-Geometrie (alpin/kristallin)
    const geometry = new THREE.IcosahedronGeometry(1.85, 4);
    const pos = geometry.attributes.position as THREE.BufferAttribute;
    const v = new THREE.Vector3();
    const seeds: number[] = [];
    for (let i = 0; i < pos.count; i++) {
      v.fromBufferAttribute(pos, i).normalize();
      const n =
        0.16 * Math.sin(v.x * 3.1 + v.y * 2.3) +
        0.10 * Math.cos(v.y * 4.0 - v.z * 2.7) +
        0.07 * Math.sin(v.z * 5.2 + v.x * 1.9);
      seeds.push(n);
      v.multiplyScalar(1.85 * (1 + n));
      pos.setXYZ(i, v.x, v.y, v.z);
    }
    geometry.computeVertexNormals();

    const mat = new THREE.MeshStandardMaterial({
      color: new THREE.Color("#efeae0"),
      roughness: 0.62,
      metalness: 0.12,
      flatShading: true,
    });
    const mesh = new THREE.Mesh(geometry, mat);

    // Dezentes Drahtgitter in Tinte
    const wire = new THREE.LineSegments(
      new THREE.WireframeGeometry(geometry),
      new THREE.LineBasicMaterial({ color: new THREE.Color("#18191b"), transparent: true, opacity: 0.10 }),
    );
    mesh.add(wire);

    const group = new THREE.Group();
    group.add(mesh);
    group.rotation.set(0.3, 0.5, 0);
    scene.add(group);

    // Licht: weiches Umgebungslicht + warmer Terracotta-Akzent von rechts oben
    scene.add(new THREE.AmbientLight(0xffffff, 0.85));
    const key = new THREE.DirectionalLight(0xffffff, 1.1);
    key.position.set(-3, 2.5, 4);
    scene.add(key);
    const accent = new THREE.PointLight(0xc24a2c, 26, 14);
    accent.position.set(3.2, 2.4, 2.5);
    scene.add(accent);

    // Größe / DPR
    function resize() {
      if (!canvas) return;
      const r = canvas.getBoundingClientRect();
      const size = Math.max(1, Math.min(r.width, r.height));
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(size, size, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener("resize", resize, { passive: true });

    // Pointer-Parallax (nur wenn Bewegung erlaubt)
    const target = { x: 0.3, y: 0.5 };
    if (!prefersReduced) {
      window.addEventListener(
        "pointermove",
        (e) => {
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / window.innerHeight) * 2 - 1;
          target.y = 0.5 + nx * 0.5;
          target.x = 0.3 + ny * 0.3;
        },
        { passive: true },
      );
    }

    function renderOnce() {
      resize();
      renderer.render(scene, camera);
    }

    if (prefersReduced) {
      renderOnce();
    } else {
      let raf = 0;
      let running = true;
      const tick = () => {
        if (!running) return;
        group.rotation.y += (target.y - group.rotation.y) * 0.04 + 0.0015;
        group.rotation.x += (target.x - group.rotation.x) * 0.04;
        renderer.render(scene, camera);
        raf = requestAnimationFrame(tick);
      };
      tick();

      // Pause außerhalb des Sichtbereichs (Performance)
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          running = entry.isIntersecting;
          if (running) tick();
          else cancelAnimationFrame(raf);
        });
      });
      io.observe(canvas);
    }
  }
</script>
