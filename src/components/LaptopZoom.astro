---
// Cineastisches Intro: echter Laptop (Higgsfield-Render, freigestellt) auf dunkler
// Bühne. Beim Laden bootet der Bildschirm automatisch ("geht an") und zeigt die
// Wortmarke "DT Webstudio". Beim Scrollen zoomt man in den Screen hinein und landet
// in der echten Live-Website (Hero), während die dunkle Bühne ins Helle aufklart.
import { u } from "../lib/url";
---

<section class="lz" aria-label="Intro">
  <div class="lz-pin">
    <!-- dunkle Bühne (klart beim Zoom ins Helle auf) -->
    <div class="lz-bg" aria-hidden="true"></div>
    <div class="lz-stagelight" aria-hidden="true"></div>
    <div class="lz-vignette" aria-hidden="true"></div>

    <!-- Gerät: wird beim Scrollen skaliert -->
    <div class="lz-device">
      <div class="lz-device-in">
        <img class="lz-photo lz-photo--laptop" src={u("/img/laptop.png")} alt="" draggable="false" />
        <img class="lz-photo lz-photo--phone" src={u("/img/phone.png")} alt="" draggable="false" />

        <!-- Screen-Overlay exakt auf der Glasfläche -->
        <div class="lz-screen">
          <div class="lz-glow" aria-hidden="true"></div>

          <!-- Boot-/Marken-Screen -->
          <div class="lz-splash">
            <span class="lz-logo">
              <span class="lz-logo-dt">DT</span>
              <span class="lz-logo-web">Webstudio</span>
            </span>
            <span class="lz-rule" aria-hidden="true"></span>
            <span class="lz-splash-sub">Schau rein – <em>scroll</em> in deine neue Website.</span>
            <span class="lz-boot"><i></i></span>
          </div>

          <!-- Screen: paper background – nahtlose Bridge zum echten Hero -->
          <div class="lz-site" aria-hidden="true">
            <span class="lz-ws-brand-center">
              <span class="lz-ws-bc-dt">DT</span>
              <span class="lz-ws-bc-web">Webstudio</span>
            </span>
          </div>

          <div class="lz-glare" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <!-- Scroll-Hinweis -->
    <div class="lz-hint" aria-hidden="true">
      <span class="lz-hint-word">scroll</span>
      <span class="lz-hint-line"></span>
    </div>

    <!-- Ohne JavaScript: Boot-Screen aus, echte Website direkt sichtbar -->
    <noscript>
      <style>
        .lz-splash { opacity: 0 !important; }
        .lz-site { opacity: 1 !important; }
        .lz-hint, .lz-glare, .lz-glow { display: none !important; }
      </style>
    </noscript>
  </div>
</section>

<style>
  .lz { position: relative; height: 100vh; background: var(--color-paper-50); }
  .lz-pin {
    position: relative; height: 100vh; width: 100%;
    overflow: hidden; display: grid; place-items: center;
  }

  /* --- Bühne --- */
  .lz-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(120% 90% at 50% 38%, #26232a 0%, #161318 46%, #0c0b0e 100%);
  }
  .lz-stagelight {
    position: absolute; z-index: 1; left: 50%; top: 44%;
    width: 78vw; height: 78vw; max-width: 1000px; max-height: 1000px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(194, 74, 44, 0.20), rgba(194,74,44,0.05) 45%, transparent 66%);
    filter: blur(24px); opacity: 0; pointer-events: none;
  }
  .lz-vignette {
    position: absolute; inset: 0; z-index: 6; pointer-events: none;
    background: radial-gradient(130% 100% at 50% 50%, transparent 58%, rgba(0,0,0,0.45) 100%);
  }

  /* --- Gerät --- */
  .lz-device {
    position: relative; z-index: 3;
    width: min(90vw, 1040px);
    aspect-ratio: 753 / 472;            /* exakt das Crop-Verhältnis des Renders */
    will-change: transform;
  }
  .lz-device-in {
    position: absolute; inset: 0;
    will-change: transform, opacity;
    filter: drop-shadow(0 60px 80px rgba(0,0,0,0.55));
  }
  .lz-photo {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: contain; user-select: none; -webkit-user-drag: none;
    z-index: 1; pointer-events: none;
  }
  .lz-photo--phone { display: none; }

  /* Screen-Overlay – sitzt exakt auf der Glasfläche (Werte aus Bildmessung) */
  .lz-screen {
    position: absolute;
    left: 13.6%; top: 5.2%; width: 72.7%; height: 79.3%;
    z-index: 2; overflow: hidden;
    background: #050507;
    border-radius: 6px;
    container-type: inline-size;
  }
  .lz-glow {
    position: absolute; inset: 0; z-index: 0; opacity: 0;
    background: radial-gradient(120% 130% at 50% 42%, rgba(255,255,255,0.10), transparent 60%);
  }

  /* Boot-Screen */
  .lz-splash {
    position: absolute; inset: 0; z-index: 2;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1.4em;
    background: radial-gradient(120% 120% at 50% 40%, #211d24 0%, #100e13 70%, #0a090c 100%);
  }
  .lz-logo {
    display: inline-flex; align-items: baseline; gap: 0.2em;
    font-family: var(--font-display); letter-spacing: -0.02em; line-height: 1;
    font-size: clamp(1.7rem, 8cqw, 4.4rem);
    opacity: 0;
  }
  .lz-logo-dt { font-weight: 500; color: #f4f1ec; }
  .lz-logo-web { font-style: italic; font-weight: 400; color: var(--color-accent); }
  .lz-rule {
    width: clamp(40px, 9cqw, 90px); height: 1px; opacity: 0;
    background: linear-gradient(90deg, transparent, rgba(194,74,44,0.9), transparent);
  }
  .lz-splash-sub {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(0.78rem, 2.5cqw, 1.25rem); line-height: 1.4; letter-spacing: -0.01em;
    color: rgba(244,241,236,0.82); text-align: center; max-width: 80%; opacity: 0;
  }
  .lz-splash-sub em { font-style: italic; color: var(--color-accent); }
  .lz-boot {
    position: relative; width: clamp(70px, 22cqw, 150px); height: 2px;
    background: rgba(255,255,255,0.12); border-radius: 2px; overflow: hidden; opacity: 0;
  }
  .lz-boot i {
    position: absolute; inset: 0; transform-origin: left center; transform: scaleX(0);
    background: linear-gradient(90deg, var(--color-accent), #e9764f);
  }

  /* Screen: paper background — nahtlose Bridge zum echten Hero via Crossfade */
  .lz-site {
    position: absolute; inset: 0; z-index: 1; opacity: 0;
    background: var(--color-paper-50);
    display: flex; align-items: center; justify-content: center;
  }
  .lz-ws-brand-center {
    display: inline-flex; align-items: baseline; gap: 0.2em;
    font-family: var(--font-display); letter-spacing: -0.02em; line-height: 1;
    font-size: clamp(1.4rem, 3.5vw, 2.8rem);
  }
  .lz-ws-bc-dt { font-weight: 500; color: var(--color-ink-900); }
  .lz-ws-bc-web { font-style: italic; font-weight: 400; color: var(--color-accent); }

  /* Glas-Reflex */
  .lz-glare {
    position: absolute; inset: 0; z-index: 3; pointer-events: none; opacity: 0;
    background: linear-gradient(118deg,
      rgba(255,255,255,0.30) 0%, rgba(255,255,255,0.05) 16%,
      transparent 34%, transparent 100%);
    mix-blend-mode: screen;
  }

  /* Scroll-Hinweis */
  .lz-hint {
    position: absolute; z-index: 7; bottom: 5vh; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem; opacity: 0;
  }
  .lz-hint-word {
    font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase;
    color: rgba(244,241,236,0.7);
  }
  .lz-hint-line { width: 1px; height: 38px; background: linear-gradient(rgba(244,241,236,0.7), transparent); }

  /* --- Mobil: Smartphone statt Laptop --- */
  @media (max-width: 767px) {
    .lz-photo--laptop { display: none; }
    .lz-photo--phone { display: block; }
    .lz-device { aspect-ratio: 414 / 820; width: min(64vw, 320px); }
    .lz-screen {
      left: 8%; top: 4.5%; width: 84%; height: 91%;
      border-radius: 26px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lz, .lz-pin { height: auto; }
    .lz-pin { padding: 8vh 1rem; }
    .lz-bg { background: var(--color-paper-50); }
    .lz-stagelight, .lz-vignette, .lz-glare, .lz-glow, .lz-hint, .lz-splash { display: none; }
    .lz-device-in { filter: drop-shadow(0 30px 50px rgba(0,0,0,0.25)); }
    .lz-site { opacity: 1; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  // iOS/Android: URL-Leiste-Resize ignorieren -> kein Springen beim Pinnen
  ScrollTrigger.config({ ignoreMobileResize: true });

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const root = document.querySelector<HTMLElement>(".lz");
  const device = document.querySelector<HTMLElement>(".lz-device");
  const screenEl = document.querySelector<HTMLElement>(".lz-screen");

  if (root && device && screenEl && !reduce) {
    // Hero-Split starts hidden; revealed via crossfade when zoom completes
    gsap.set(".hero-split", { opacity: 0 });

    // --- 1) Auto-Boot beim Laden (straff: ~1.2s statt ~2.5s) -------------
    const intro = gsap.timeline({ delay: 0.15 });
    intro
      .fromTo(".lz-device-in",
        { opacity: 0, y: 26, scale: 0.985 },
        { opacity: 1, y: 0, scale: 1, duration: 0.6, ease: "power3.out" })
      // Bildschirm "geht an": Backlight blitzt auf
      .fromTo(".lz-glow", { opacity: 0 }, { opacity: 1, duration: 0.14, ease: "power2.out" }, 0.25)
      .to(".lz-glow", { opacity: 0.35, duration: 0.3, ease: "power2.inOut" }, ">")
      // Boot-Balken läuft durch
      .set(".lz-boot", { opacity: 1 }, 0.35)
      .fromTo(".lz-boot i", { scaleX: 0 }, { scaleX: 1, duration: 0.4, ease: "power1.inOut" }, 0.37)
      .to(".lz-boot", { opacity: 0, duration: 0.2 }, ">-0.05")
      // Wortmarke erscheint
      .fromTo(".lz-logo",
        { opacity: 0, y: 12, filter: "blur(6px)" },
        { opacity: 1, y: 0, filter: "blur(0px)", duration: 0.5, ease: "power3.out" }, "<")
      // Akzentlinie + Subline
      .fromTo(".lz-rule", { opacity: 0, scaleX: 0.4 }, { opacity: 1, scaleX: 1, duration: 0.35, ease: "power2.out" }, "<0.1")
      .fromTo(".lz-splash-sub", { opacity: 0, y: 8 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" }, "<0.05")
      .fromTo(".lz-glare", { opacity: 0 }, { opacity: 1, duration: 0.4 }, "<")
      .fromTo(".lz-stagelight", { opacity: 0 }, { opacity: 1, duration: 0.6, ease: "sine.out" }, 0.3)
      .to(".lz-hint", { opacity: 1, duration: 0.4 }, ">-0.15");

    // dezenter Puls am Scroll-Hinweis
    gsap.to(".lz-hint-line", {
      scaleY: 0.45, transformOrigin: "top center", duration: 1, ease: "sine.inOut",
      repeat: -1, yoyo: true, delay: 2.4,
    });

    // --- 2) Zoom-Mathematik (misst die echte Glas-/Screen-Position) ----
    const zoom = { tx: 0, ty: 0, scale: 6 };
    function computeZoom() {
      const saved = device!.style.transform;
      device!.style.transform = "none";
      const dr = device!.getBoundingClientRect();
      const sr = screenEl!.getBoundingClientRect();
      device!.style.transform = saved;
      const scx = sr.left + sr.width / 2;
      const scy = sr.top + sr.height / 2;
      gsap.set(device!, { transformOrigin: `${scx - dr.left}px ${scy - dr.top}px` });
      zoom.tx = window.innerWidth / 2 - scx;
      zoom.ty = window.innerHeight / 2 - scy;
      // Auf Breite zoomen (das Foto blendet am Ende aus, vertikale Lücken sind Paper).
      // Querformat-Screen würde sonst auf Hochformat-Handys extrem überskalieren.
      zoom.scale = (window.innerWidth / sr.width) * 1.01;
    }
    computeZoom();

    // --- 3) Scroll-Timeline: rein in den Screen -------------------------
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: "top top",
        end: "+=100%",
        pin: true,
        anticipatePin: 1,
        scrub: 1,
        invalidateOnRefresh: true,
        onRefresh: computeZoom,
      },
    });

    // Hinweis, Reflex früh weg
    tl.to(".lz-hint", { opacity: 0, duration: 0.12 }, 0)
      .to(".lz-glare", { opacity: 0, duration: 0.25 }, 0.05);

    // Marke weicht der echten Website
    tl.to(".lz-splash", { opacity: 0, duration: 0.3, ease: "power1.in" }, 0.12)
      .to(".lz-site", { opacity: 1, duration: 0.3, ease: "power1.out" }, 0.16);

    // Hineinzoomen (Glas füllt den Viewport)
    tl.to(device, {
      x: () => zoom.tx, y: () => zoom.ty, scale: () => zoom.scale,
      ease: "power2.inOut", duration: 0.72,
    }, 0);

    // Bühne klart auf, Drop-Shadow + Glow lösen sich
    tl.to(".lz-bg", { opacity: 0, duration: 0.22, ease: "none" }, 0.55)
      .to(".lz-stagelight", { opacity: 0, duration: 0.25 }, 0.5)
      .to(".lz-glow", { opacity: 0, duration: 0.25 }, 0.55)
      .to(".lz-vignette", { opacity: 0, duration: 0.3 }, 0.6)
      .to(".lz-device-in", { filter: "drop-shadow(0 0 0 rgba(0,0,0,0))", duration: 0.3, ease: "none" }, 0.6)
      .to(".lz-screen", { borderRadius: 0, duration: 0.2 }, 0.66)
      // Rahmen löst sich auf, während man eintaucht – nur die Website bleibt
      .to(".lz-photo", { opacity: 0, duration: 0.22, ease: "power1.in" }, 0.6);

    // Crossfade: scrub-getrieben → funktioniert bei beliebiger Scroll-Geschwindigkeit
    tl.to(".lz-pin", { opacity: 0, duration: 0.12, ease: "none" }, 0.88)
      .to(".hero-split", { opacity: 1, duration: 0.12, ease: "none" }, 0.90);
  }
</script>
