---
interface Props {
  variant?: "dark" | "light";
}
const { variant = "dark" } = Astro.props;
const base = variant === "light" ? "text-paper-50" : "text-ink-900";
---

<span class={`inline-flex items-baseline gap-[0.15em] font-display text-[1.4rem] leading-none tracking-[-0.02em] ${base}`}>
  <span class="font-medium">DT</span>
  <span class="italic font-normal text-accent">Webstudio</span>
</span>
