---
import type { Step } from "../data/site";
interface Props {
  step: Step;
  index: number;
  last?: boolean;
}
const { step, index, last = false } = Astro.props;
const num = String(index + 1).padStart(2, "0");
---

<li class="reveal relative flex gap-5 pb-10 last:pb-0" style={`--reveal-delay: ${index * 80}ms;`}>
  <!-- Verbindungslinie -->
  {!last && (
    <span aria-hidden="true" class="absolute left-[1.4rem] top-12 h-[calc(100%-2.5rem)] w-px bg-line"></span>
  )}
  <span
    class="relative z-10 flex h-[2.8rem] w-[2.8rem] shrink-0 items-center justify-center rounded-full border border-line bg-paper-50 font-display text-lg text-accent"
  >
    {num}
  </span>
  <div class="pt-1.5">
    <h3 class="text-xl text-ink-900">{step.title}</h3>
    <p class="mt-2 max-w-md text-[0.97rem] leading-relaxed text-ink-500">{step.text}</p>
  </div>
</li>
