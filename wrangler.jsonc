{
  // Statische Astro-Seite als Cloudflare Workers Static Assets ausliefern.
  // Kein "main"/Server-Script -> reines Static-Hosting des dist-Ordners.
  // Dadurch deployt `wrangler deploy` direkt die fertigen Dateien, ohne
  // den SSR-Adapter (@astrojs/cloudflare) nachinstallieren zu wollen.
  "name": "dt-webstudio",
  "compatibility_date": "2025-06-22",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
